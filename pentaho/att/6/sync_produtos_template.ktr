  <step>
    <name>Leitura Produtos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>EcoCentauro_Local</connection>
    <sql>SELECT
  PROD.CODIGO AS CODIGO_INTERNO
, PROD.CODIGOBARRA
, PROD.DESCRICAO
, PROD.REFERENCIA
, PROD.PRODUTOPRINCIPAL
, PROD2.CUSTOORIGEM
, PROD2.CUSTOFINAL
, PROD2.PRSUGERIDO
, PROD2.ESTDISPONIVEL
, PROD2.MARGEMLUCRO
, PROD.QTDEEMBALAGEM
FROM TESTPRODUTOGERAL PROD
JOIN TESTPRODUTO PROD2 ON PROD.CODIGO = PROD2.PRODUTO
WHERE PROD2.EMPRESA = 01
  AND PROD2.ATIVO = 'S'
  AND PROD.CODIGOBARRA IS NOT NULL
  AND TRIM(PROD.CODIGOBARRA) &lt;&gt; ''
  AND PROD.CODIGO = (
    SELECT FIRST 1 P3.CODIGO
      FROM TESTPRODUTOGERAL P3
      JOIN TESTPRODUTO P4 ON P3.CODIGO = P4.PRODUTO
     WHERE P4.EMPRESA = 01
       AND P4.ATIVO = 'S'
       AND P3.CODIGOBARRA = PROD.CODIGOBARRA
     ORDER BY
       CASE WHEN P3.CODIGO = P3.PRODUTOPRINCIPAL THEN 0 ELSE 1 END,
       P3.CODIGO
  )</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
      <value-meta>
        <type>String</type>
        <storagetype>normal</storagetype>
        <name>CODIGO_INTERNO</name>
        <length>6</length>
        <precision>-1</precision>
        <origin>Leitura Produtos</origin>
        <comments>CODIGO_INTERNO</comments>
        <conversion_Mask/>
        <decimal_symbol>,</decimal_symbol>
