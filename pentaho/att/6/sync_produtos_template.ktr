    <lookup>
      <key>
        <name>PRODUTOPRINCIPAL</name>
        <field>PRODUTOPRINCIPAL</field>
      </key>
      <value>
        <name>ULTIMA_VENDA</name>
        <rename>ULTIMA_VENDA</rename>
        <default/>
        <type>Date</type>
      </value>
    </lookup>
    <attributes/>
    <cluster_schema/>
