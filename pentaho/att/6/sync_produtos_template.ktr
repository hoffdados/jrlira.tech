  <step>
    <name>Leitura Promos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>EcoCentauro_Local</connection>
    <sql>SELECT
  PG.CODIGOBARRA
, TP.IDTABELAPRECO
, TP.DESCRICAO AS NOME_TABELA
, TPP.PRSUGERIDO AS PRECO_PROMOCIONAL
, TPP.PRANTERIOR
, TPP.QTDEPROMOCAO
, TP.DATAVALIDADEINICIO AS DATA_INICIO
, TP.DATAVALIDADEFIM AS DATA_FIM
, TPP.DATAALTERACAO AS DATA_ALTERACAO
, TP.ATIVO
FROM TESTTABELAPRECO TP
JOIN TESTTABELAPRECOPRODUTOS TPP
  ON TP.IDTABELAPRECO = TPP.IDTABELAPRECO
 AND TP.EMPRESA = TPP.EMPRESA
JOIN TESTPRODUTOGERAL PG
  ON TPP.PRODUTO = PG.CODIGO
WHERE TP.EMPRESA = 01
  AND TP.TIPOPRECO = 'P'
  AND TP.ATIVO = 'S'
  AND PG.CODIGOBARRA IS NOT NULL
  AND TRIM(PG.CODIGOBARRA) &lt;&gt; ''</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta/>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>112</xloc>
      <yloc>288</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Leitura Ultima Venda</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>EcoCentauro_Local</connection>
    <sql>SELECT
  PROD.PRODUTOPRINCIPAL
, MAX(PED.DATAEFE) AS ULTIMA_VENDA
FROM TVENPRODUTO PROD
JOIN TVENPEDIDO PED ON PROD.PEDIDO = PED.CODIGO
JOIN TVENREGISTRO REG ON PROD.PEDIDO = REG.IDPEDIDO
JOIN TESTNATUREZA NAT ON PED.TIPOOPERACAO = NAT.CODIGO
WHERE PED.STATUS = 'EFE'
  AND NAT.GERAFINANCEIRO = 'S'
  AND NAT.MOVIMENTAESTOQUE = 'S'
  AND PROD.EMPRESA = 01
  AND PED.DATAEFE >= CAST('2025-01-01' AS DATE)
GROUP BY PROD.PRODUTOPRINCIPAL</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta/>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>304</xloc>
      <yloc>48</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
