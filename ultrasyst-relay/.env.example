RELAY_PORT=8787
# Token forte (32+ chars). Gere com:
# [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
RELAY_TOKEN=

# Defesa em profundidade (opcional). Se setar, todo pedido precisa do header:
RELAY_SECRET_HEADER=
RELAY_SECRET_VALUE=

# Allowlist de IP (opcional). Se vazio, aceita qualquer IP autenticado.
# Em produção, colocar o IP do Railway.
ALLOWLIST_IPS=

# SQL
SQL_HOST=127.0.0.1
SQL_PORT=1433
SQL_DB=ITAUTUBA
SQL_USER=ASAB
SQL_PASS=

# Limites
MAX_ROWS=5000
RATE_PER_MIN=120

# Logs (audit trail)
LOG_DIR=C:\ultrasyst-relay\logs
